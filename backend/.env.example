# =============================================================================
# LawMind AI - 本地开发环境配置
# =============================================================================
# 复制此文件为 .env.local 进行本地开发覆盖
# 生产环境请使用环境变量或密钥管理服务，不要使用此文件中的默认值
# =============================================================================

# ── 应用基础配置 ──────────────────────────────────────────────
APP_NAME=LawMind AI
# 环境：development | staging | production
ENVIRONMENT=development
# 仅在开发环境启用调试模式，生产环境必须设为 false
APP_DEBUG=true
# 应用密钥：用于session签名等。生产环境必须使用强随机字符串！
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=dev-secret-key-local
APP_HOST=0.0.0.0
APP_PORT=8000

# ── 数据库配置 ────────────────────────────────────────────────
# 开发环境使用 SQLite
DATABASE_URL=sqlite+aiosqlite:///./lawmind.db
DATABASE_URL_SYNC=sqlite:///./lawmind.db
# 生产环境使用 PostgreSQL（docker-compose 会自动覆盖）：
# DATABASE_URL=postgresql+asyncpg://lawmind:lawmind123@localhost:5432/lawmind
# DATABASE_URL_SYNC=postgresql://lawmind:lawmind123@localhost:5432/lawmind

# ── Redis 配置 ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT 认证配置 ──────────────────────────────────────────────
# JWT密钥：生产环境必须使用强随机字符串！绝不能使用默认值！
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-jwt-secret-local
JWT_ALGORITHM=HS256
# 访问令牌过期时间（分钟）
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── LLM API 配置 ─────────────────────────────────────────────
# API密钥：请替换为您自己的密钥
CLAUDE_API_KEY=your-api-key-here
# API 基础URL（支持 OpenAI 兼容接口）
CLAUDE_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# 模型名称
CLAUDE_MODEL=glm-5.1
# 最大输出 token 数
CLAUDE_MAX_TOKENS=4096

# ── ChromaDB 向量数据库配置 ──────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=lawmind_docs

# ── 北大法宝 MCP 法律数据源 ─────────────────────────────────
CHINESE_LAW_MCP_ENABLED=true

# ── Embedding 模型配置 ────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
# 自定义 Embedding API 地址（留空使用本地模型）
EMBEDDING_BASE_URL=

# ── 文件上传配置 ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE_MB=50

# ── CORS 跨域配置 ────────────────────────────────────────────
# 允许的前端来源，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
