# LawMind AI 环境配置
# 复制为 .env 并填入实际值

# === 应用配置 ===
APP_NAME=LawMind AI
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000

# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://lawmind:lawmind123@localhost:5432/lawmind
DATABASE_URL_SYNC=postgresql://lawmind:lawmind123@localhost:5432/lawmind

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === JWT ===
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# === Claude API ===
CLAUDE_API_KEY=sk-ant-your-claude-api-key
CLAUDE_MODEL=claude-opus-4-7
CLAUDE_MAX_TOKENS=4096

# === 向量数据库 ===
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=lawmind_docs

# === 北大法宝 MCP ===
CHINESE_LAW_MCP_ENABLED=true

# === 天眼查 ===
TIANYANCHA_API_KEY=
TIANYANCHA_API_URL=https://open.api.tianyancha.com

# === 企查查 ===
QICHACHA_API_KEY=
QICHACHA_API_URL=https://api.qichacha.com

# === 文件存储 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# === CORS ===
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
