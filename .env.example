# =============================================================================
# LawMind AI - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values.
# All settings can also be overridden via environment variables.

# --- Application ---
APP_NAME=LawMind AI
# Options: development | staging | production
# In production, insecure default secrets are rejected at startup.
ENVIRONMENT=development
# Backward compat alias (deprecated, prefer ENVIRONMENT)
APP_ENV=development
APP_DEBUG=true
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=change-me-to-a-random-secret-key
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Database ---
# SQLite (default, for development):
# DATABASE_URL=sqlite+aiosqlite:///./lawmind.db
# DATABASE_URL_SYNC=sqlite:///./lawmind.db
# PostgreSQL (recommended for staging/production):
DATABASE_URL=postgresql+asyncpg://lawmind:lawmind123@localhost:5432/lawmind
DATABASE_URL_SYNC=postgresql://lawmind:lawmind123@localhost:5432/lawmind

# --- Redis (used for rate limiting and caching) ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-to-a-random-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- AI / LLM (Anthropic-compatible API) ---
# Example: Anthropic Claude, Zhipu GLM via Anthropic-compatible endpoint
CLAUDE_API_KEY=sk-ant-your-api-key-here
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# --- Vector Database (ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=lawmind_docs

# --- Chinese Law MCP (北大法宝 integration) ---
# Enables legal database queries via the Chinese Law MCP server
CHINESE_LAW_MCP_ENABLED=true

# --- Enterprise Data APIs ---
# Tianyancha (天眼查) - Company information lookup
TIANYANCHA_API_KEY=
TIANYANCHA_API_URL=https://open.api.tianyancha.com
# Qichacha (企查查) - Business registration data
QICHACHA_API_KEY=
QICHACHA_API_URL=https://api.qichacha.com

# --- Embedding Model ---
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Leave empty to use the default HuggingFace model locally
EMBEDDING_BASE_URL=

# --- File Uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# --- CORS (Comma-separated allowed origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
# Must be one of: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Set to a file path to enable rotating file logging (recommended in production)
# LOG_FILE=./logs/lawmind.log
LOG_FILE=

# --- Security Headers (applied automatically in production) ---
# HTTP Strict Transport Security, X-Content-Type-Options, X-Frame-Options, etc.
# are enforced when ENVIRONMENT=production. No extra config needed.

# --- Rate Limiting ---
# Default limits are compiled into the application. Adjust in code if needed:
#   - Auth endpoints: 5 requests/minute
#   - General API: 60 requests/minute
#   - Health check: 120 requests/minute

# --- Error Email Notifications (production) ---
# When enabled, emails are sent on unhandled errors (level >= ERROR).
ERROR_EMAIL_ENABLED=false
# ERROR_EMAIL_SMTP_HOST=smtp.example.com
# ERROR_EMAIL_SMTP_PORT=587
# ERROR_EMAIL_SMTP_USER=noreply@example.com
# ERROR_EMAIL_SMTP_PASSWORD=smtp-password
# ERROR_EMAIL_FROM=noreply@example.com
# ERROR_EMAIL_TO=admin@example.com,ops@example.com
